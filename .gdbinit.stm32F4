##
## .gdbinit.stm32f4

define load_dma
   source lib/stm32-make/STM32F411/gdbinit/.gdbinit.stm32f411.dma1
   source lib/stm32-make/STM32F411/gdbinit/.gdbinit.stm32f411.dma2
end

define load_exti
   source lib/stm32-make/STM32F411/gdbinit/.gdbinit.stm32f411.exti
end

define load_gpio
   source lib/stm32-make/STM32F411/gdbinit/.gdbinit.stm32f411.gpioa
   source lib/stm32-make/STM32F411/gdbinit/.gdbinit.stm32f411.gpiob
   source lib/stm32-make/STM32F411/gdbinit/.gdbinit.stm32f411.gpioc
