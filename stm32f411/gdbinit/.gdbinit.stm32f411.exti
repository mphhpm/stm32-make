    ###########################
    ##        PR             ##
    ###########################
    set $addr = $baseaddr + $PR
    set $data = *$addr
    printf "EXTI.PR      0x%4x %4x: 0x%08x", ($addr >> 16), ($addr & 0xFFFF), *$addr 
    printf "     "
    printf "PR22[22]=%d ", (($data >> 22) & 0x01)
