    printf "MR12:%d ", (($addr >> 12) & 0x01)
    printf "MR11:%d ", (($addr >> 11) & 0x01)
    printf "MR10:%d ", (($addr >> 10) & 0x01)
    printf "MR9:%d ", (($addr >> 9) & 0x01)
    printf "MR8:%d ", (($addr >> 8) & 0x01)
    printf "MR7:%d ", (($addr >> 7) & 0x01)
    printf "MR6:%d ", (($addr >> 6) & 0x01)
    printf "MR5:%d ", (($addr >> 5) & 0x01)
    printf "MR4:%d ", (($addr >> 4) & 0x01)
    printf "MR3:%d ", (($addr >> 3) & 0x01)
    printf "MR2:%d ", (($addr >> 2) & 0x01)
    printf "MR1:%d ", (($addr >> 1) & 0x01)
    printf "MR0:%d ", (($addr >> 0) & 0x01)
    printf "\n"

    ###########################
