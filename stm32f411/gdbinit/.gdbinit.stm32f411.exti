    printf "MR5[5]=%d ", (($data >> 5) & 0x01)
    printf "MR4[4]=%d ", (($data >> 4) & 0x01)
    printf "MR3[3]=%d ", (($data >> 3) & 0x01)
    printf "MR2[2]=%d ", (($data >> 2) & 0x01)
    printf "MR1[1]=%d ", (($data >> 1) & 0x01)
    printf "MR0[0]=%d ", (($data >> 0) & 0x01)
    printf "\n"

    ###########################
    ##        EMR            ##
    ###########################
    set $addr = $baseaddr + $EMR
    set $data = *$addr
    printf "EXTI.EMR     0x%4x %4x: 0x%08x", ($addr >> 16), ($addr & 0xFFFF), *$addr 
