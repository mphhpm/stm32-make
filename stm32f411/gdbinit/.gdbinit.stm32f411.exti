    ###########################
    set $addr = $baseaddr + $FTSR
    printf "EXTI.FTSR    0x%4x %4x: 0x%08x", ($addr >> 16), ($addr & 0xFFFF), *$addr 
    printf "     "
    printf "TR22:%d ", (($addr >> 22) & 0x01)
    printf "TR21:%d ", (($addr >> 21) & 0x01)
    printf "TR20:%d ", (($addr >> 20) & 0x01)
    printf "TR19:%d ", (($addr >> 19) & 0x01)
    printf "TR18:%d ", (($addr >> 18) & 0x01)
