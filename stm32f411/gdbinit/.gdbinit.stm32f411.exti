    printf "TR12:%d ", (($addr >> 12) & 0x01)
    printf "TR11:%d ", (($addr >> 11) & 0x01)
    printf "TR10:%d ", (($addr >> 10) & 0x01)
    printf "TR9:%d ", (($addr >> 9) & 0x01)
    printf "TR8:%d ", (($addr >> 8) & 0x01)
    printf "TR7:%d ", (($addr >> 7) & 0x01)
