    printf "TR1[1]=%d ", (($data >> 1) & 0x01)
    printf "TR0[0]=%d ", (($data >> 0) & 0x01)
    printf "\n"

    ###########################
    ##        SWIER          ##
    ###########################
    set $addr = $baseaddr + $SWIER
    set $data = *$addr
    printf "EXTI.SWIER   0x%4x %4x: 0x%08x", ($addr >> 16), ($addr & 0xFFFF), *$addr 
    printf "     "
    printf "SWIER22[22]=%d ", (($data >> 22) & 0x01)
    printf "SWIER21[21]=%d ", (($data >> 21) & 0x01)
    printf "SWIER20[20]=%d ", (($data >> 20) & 0x01)
    printf "SWIER19[19]=%d ", (($data >> 19) & 0x01)
    printf "SWIER18[18]=%d ", (($data >> 18) & 0x01)
    printf "SWIER17[17]=%d ", (($data >> 17) & 0x01)
    printf "SWIER16[16]=%d ", (($data >> 16) & 0x01)
    printf "SWIER15[15]=%d ", (($data >> 15) & 0x01)
    printf "SWIER14[14]=%d ", (($data >> 14) & 0x01)
    printf "SWIER13[13]=%d ", (($data >> 13) & 0x01)
    printf "SWIER12[12]=%d ", (($data >> 12) & 0x01)
    printf "SWIER11[11]=%d ", (($data >> 11) & 0x01)
    printf "SWIER10[10]=%d ", (($data >> 10) & 0x01)
    printf "SWIER9[9]=%d ", (($data >> 9) & 0x01)
    printf "SWIER8[8]=%d ", (($data >> 8) & 0x01)
    printf "SWIER7[7]=%d ", (($data >> 7) & 0x01)
    printf "SWIER6[6]=%d ", (($data >> 6) & 0x01)
    printf "SWIER5[5]=%d ", (($data >> 5) & 0x01)
