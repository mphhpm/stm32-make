    printf "SWIER18:%d ", (($addr >> 18) & 0x01)
    printf "SWIER17:%d ", (($addr >> 17) & 0x01)
    printf "SWIER16:%d ", (($addr >> 16) & 0x01)
    printf "SWIER15:%d ", (($addr >> 15) & 0x01)
    printf "SWIER14:%d ", (($addr >> 14) & 0x01)
    printf "SWIER13:%d ", (($addr >> 13) & 0x01)
    printf "SWIER12:%d ", (($addr >> 12) & 0x01)
    printf "SWIER11:%d ", (($addr >> 11) & 0x01)
    printf "SWIER10:%d ", (($addr >> 10) & 0x01)
    printf "SWIER9:%d ", (($addr >> 9) & 0x01)
    printf "SWIER8:%d ", (($addr >> 8) & 0x01)
    printf "SWIER7:%d ", (($addr >> 7) & 0x01)
    printf "SWIER6:%d ", (($addr >> 6) & 0x01)
    printf "SWIER5:%d ", (($addr >> 5) & 0x01)
    printf "SWIER4:%d ", (($addr >> 4) & 0x01)
    printf "SWIER3:%d ", (($addr >> 3) & 0x01)
    printf "SWIER2:%d ", (($addr >> 2) & 0x01)
    printf "SWIER1:%d ", (($addr >> 1) & 0x01)
    printf "SWIER0:%d ", (($addr >> 0) & 0x01)
    printf "\n"

    ###########################
    ##        PR             ##
    ###########################
    set $addr = $baseaddr + $PR
    printf "EXTI.PR      0x%4x %4x: 0x%08x", ($addr >> 16), ($addr & 0xFFFF), *$addr 
    printf "     "
    printf "PR22:%d ", (($addr >> 22) & 0x01)
    printf "PR21:%d ", (($addr >> 21) & 0x01)
    printf "PR20:%d ", (($addr >> 20) & 0x01)
    printf "PR19:%d ", (($addr >> 19) & 0x01)
    printf "PR18:%d ", (($addr >> 18) & 0x01)
    printf "PR17:%d ", (($addr >> 17) & 0x01)
    printf "PR16:%d ", (($addr >> 16) & 0x01)
    printf "PR15:%d ", (($addr >> 15) & 0x01)
    printf "PR14:%d ", (($addr >> 14) & 0x01)
    printf "PR13:%d ", (($addr >> 13) & 0x01)
    printf "PR12:%d ", (($addr >> 12) & 0x01)
    printf "PR11:%d ", (($addr >> 11) & 0x01)
    printf "PR10:%d ", (($addr >> 10) & 0x01)
    printf "PR9:%d ", (($addr >> 9) & 0x01)
