####
#### EXTI
set $IMR             = 0x0
set $EMR             = 0x4
set $RTSR            = 0x8
set $FTSR            = 0xc
set $SWIER           = 0x10
set $PR              = 0x14

printf "loading print_exti\n"

define print_exti

    set $baseaddr = 0x40013c00
    ###########################
    ##        IMR            ##
    ###########################
    set $addr = $baseaddr + $IMR
    set $data = *$addr
    printf "EXTI.IMR     0x%4x %4x: 0x%08x", ($addr >> 16), ($addr & 0xFFFF), *$addr 
    printf "     "
    printf "MR22[22]=%d ", (($data >> 22) & 0x01)
    printf "MR21[21]=%d ", (($data >> 21) & 0x01)
    printf "MR20[20]=%d ", (($data >> 20) & 0x01)
    printf "MR19[19]=%d ", (($data >> 19) & 0x01)
    printf "MR18[18]=%d ", (($data >> 18) & 0x01)
    printf "MR17[17]=%d ", (($data >> 17) & 0x01)
    printf "MR16[16]=%d ", (($data >> 16) & 0x01)
    printf "MR15[15]=%d ", (($data >> 15) & 0x01)
    printf "MR14[14]=%d ", (($data >> 14) & 0x01)
    printf "MR13[13]=%d ", (($data >> 13) & 0x01)
    printf "MR12[12]=%d ", (($data >> 12) & 0x01)
    printf "MR11[11]=%d ", (($data >> 11) & 0x01)
    printf "MR10[10]=%d ", (($data >> 10) & 0x01)
