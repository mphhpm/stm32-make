set $S6PAR           = 0xa8
set $S6M0AR          = 0xac
set $S6M1AR          = 0xb0
set $S6FCR           = 0xb4
set $S7CR            = 0xb8
set $S7NDTR          = 0xbc
set $S7PAR           = 0xc0
set $S7M0AR          = 0xc4
set $S7M1AR          = 0xc8
set $S7FCR           = 0xcc

printf "loading print_dma2\n"

define print_dma2

    set $baseaddr = 0x40026400
    ###########################
    ##        LISR           ##
    ###########################
    set $addr = $baseaddr + $LISR
    set $data = *$addr
    printf "DMA2.LISR    0x%4x %4x: 0x%08x", ($addr >> 16), ($addr & 0xFFFF), *$addr 
    printf "     "
    printf "TCIF3[27]=%d ", (($data >> 27) & 0x01)
    printf "HTIF3[26]=%d ", (($data >> 26) & 0x01)
    printf "TEIF3[25]=%d ", (($data >> 25) & 0x01)
    printf "DMEIF3[24]=%d ", (($data >> 24) & 0x01)
    printf "FEIF3[22]=%d ", (($data >> 22) & 0x01)
    printf "TCIF2[21]=%d ", (($data >> 21) & 0x01)
    printf "HTIF2[20]=%d ", (($data >> 20) & 0x01)
    printf "TEIF2[19]=%d ", (($data >> 19) & 0x01)
    printf "DMEIF2[18]=%d ", (($data >> 18) & 0x01)
    printf "FEIF2[16]=%d ", (($data >> 16) & 0x01)
    printf "TCIF1[11]=%d ", (($data >> 11) & 0x01)
    printf "HTIF1[10]=%d ", (($data >> 10) & 0x01)
    printf "TEIF1[9]=%d ", (($data >> 9) & 0x01)
    printf "DMEIF1[8]=%d ", (($data >> 8) & 0x01)
