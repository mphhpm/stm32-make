####
#### DMA2
set $LISR            = 0x0
set $HISR            = 0x4
set $LIFCR           = 0x8
set $HIFCR           = 0xc
set $S0CR            = 0x10
set $S0NDTR          = 0x14
set $S0PAR           = 0x18
set $S0M0AR          = 0x1c
set $S0M1AR          = 0x20
set $S0FCR           = 0x24
set $S1CR            = 0x28
set $S1NDTR          = 0x2c
set $S1PAR           = 0x30
set $S1M0AR          = 0x34
set $S1M1AR          = 0x38
set $S1FCR           = 0x3c
set $S2CR            = 0x40
set $S2NDTR          = 0x44
set $S2PAR           = 0x48
set $S2M0AR          = 0x4c
set $S2M1AR          = 0x50
set $S2FCR           = 0x54
set $S3CR            = 0x58
set $S3NDTR          = 0x5c
set $S3PAR           = 0x60
set $S3M0AR          = 0x64
set $S3M1AR          = 0x68
set $S3FCR           = 0x6c
set $S4CR            = 0x70
set $S4NDTR          = 0x74
set $S4PAR           = 0x78
set $S4M0AR          = 0x7c
set $S4M1AR          = 0x80
set $S4FCR           = 0x84
set $S5CR            = 0x88
set $S5NDTR          = 0x8c
set $S5PAR           = 0x90
set $S5M0AR          = 0x94
set $S5M1AR          = 0x98
set $S5FCR           = 0x9c
set $S6CR            = 0xa0
