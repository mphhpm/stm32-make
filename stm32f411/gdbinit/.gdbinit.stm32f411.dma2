####
#### DMA2
set $LISR            = 0x0
set $HISR            = 0x4
set $LIFCR           = 0x8
set $HIFCR           = 0xc
set $S0CR            = 0x10
set $S0NDTR          = 0x14
set $S0PAR           = 0x18
set $S0M0AR          = 0x1c
set $S0M1AR          = 0x20
set $S0FCR           = 0x24
set $S1CR            = 0x28
set $S1NDTR          = 0x2c
set $S1PAR           = 0x30
set $S1M0AR          = 0x34
set $S1M1AR          = 0x38
set $S1FCR           = 0x3c
set $S2CR            = 0x40
set $S2NDTR          = 0x44
set $S2PAR           = 0x48
set $S2M0AR          = 0x4c
set $S2M1AR          = 0x50
set $S2FCR           = 0x54
set $S3CR            = 0x58
set $S3NDTR          = 0x5c
set $S3PAR           = 0x60
set $S3M0AR          = 0x64
set $S3M1AR          = 0x68
set $S3FCR           = 0x6c
set $S4CR            = 0x70
set $S4NDTR          = 0x74
set $S4PAR           = 0x78
set $S4M0AR          = 0x7c
set $S4M1AR          = 0x80
set $S4FCR           = 0x84
set $S5CR            = 0x88
set $S5NDTR          = 0x8c
set $S5PAR           = 0x90
set $S5M0AR          = 0x94
set $S5M1AR          = 0x98
set $S5FCR           = 0x9c
set $S6CR            = 0xa0
set $S6NDTR          = 0xa4
set $S6PAR           = 0xa8
set $S6M0AR          = 0xac
set $S6M1AR          = 0xb0
set $S6FCR           = 0xb4
set $S7CR            = 0xb8
set $S7NDTR          = 0xbc
set $S7PAR           = 0xc0
set $S7M0AR          = 0xc4
set $S7M1AR          = 0xc8
set $S7FCR           = 0xcc

define print_dma2

    set $baseaddr = 0x40026400
    ###########################
    ##        LISR           ##
    ###########################
    set $addr = $baseaddr + $LISR
    printf "DMA2.LISR    0x%4x %4x: 0x%08x", ($addr >> 16), ($addr & 0xFFFF), *$addr 
    printf "     "
    printf "TCIF3:%d ", (($addr >> 27) & 0x01)
    printf "HTIF3:%d ", (($addr >> 26) & 0x01)
    printf "TEIF3:%d ", (($addr >> 25) & 0x01)
    printf "DMEIF3:%d ", (($addr >> 24) & 0x01)
    printf "FEIF3:%d ", (($addr >> 22) & 0x01)
    printf "TCIF2:%d ", (($addr >> 21) & 0x01)
    printf "HTIF2:%d ", (($addr >> 20) & 0x01)
    printf "TEIF2:%d ", (($addr >> 19) & 0x01)
    printf "DMEIF2:%d ", (($addr >> 18) & 0x01)
    printf "FEIF2:%d ", (($addr >> 16) & 0x01)
    printf "TCIF1:%d ", (($addr >> 11) & 0x01)
    printf "HTIF1:%d ", (($addr >> 10) & 0x01)
    printf "TEIF1:%d ", (($addr >> 9) & 0x01)
    printf "DMEIF1:%d ", (($addr >> 8) & 0x01)
    printf "FEIF1:%d ", (($addr >> 6) & 0x01)
    printf "TCIF0:%d ", (($addr >> 5) & 0x01)
    printf "HTIF0:%d ", (($addr >> 4) & 0x01)
    printf "TEIF0:%d ", (($addr >> 3) & 0x01)
    printf "DMEIF0:%d ", (($addr >> 2) & 0x01)
    printf "FEIF0:%d ", (($addr >> 0) & 0x01)
    printf "\n"

    ###########################
    ##        HISR           ##
    ###########################
    set $addr = $baseaddr + $HISR
    printf "DMA2.HISR    0x%4x %4x: 0x%08x", ($addr >> 16), ($addr & 0xFFFF), *$addr 
    printf "     "
    printf "TCIF7:%d ", (($addr >> 27) & 0x01)
    printf "HTIF7:%d ", (($addr >> 26) & 0x01)
    printf "TEIF7:%d ", (($addr >> 25) & 0x01)
    printf "DMEIF7:%d ", (($addr >> 24) & 0x01)
    printf "FEIF7:%d ", (($addr >> 22) & 0x01)
    printf "TCIF6:%d ", (($addr >> 21) & 0x01)
