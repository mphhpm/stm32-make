    printf "TCIF5:%d ", (($addr >> 11) & 0x01)
    printf "HTIF5:%d ", (($addr >> 10) & 0x01)
    printf "TEIF5:%d ", (($addr >> 9) & 0x01)
    printf "DMEIF5:%d ", (($addr >> 8) & 0x01)
    printf "FEIF5:%d ", (($addr >> 6) & 0x01)
    printf "TCIF4:%d ", (($addr >> 5) & 0x01)
    printf "HTIF4:%d ", (($addr >> 4) & 0x01)
    printf "TEIF4:%d ", (($addr >> 3) & 0x01)
    printf "DMEIF4:%d ", (($addr >> 2) & 0x01)
    printf "FEIF4:%d ", (($addr >> 0) & 0x01)
    printf "\n"

    ###########################
    ##        LIFCR          ##
    ###########################
