####
#### RTC
set $TR              = 0x0
set $DR              = 0x4
set $CR              = 0x8
set $ISR             = 0xc
set $PRER            = 0x10
set $WUTR            = 0x14
set $CALIBR          = 0x18
set $ALRMAR          = 0x1c
set $ALRMBR          = 0x20
set $WPR             = 0x24
set $SSR             = 0x28
set $SHIFTR          = 0x2c
set $TSTR            = 0x30
set $TSDR            = 0x34
set $TSSSR           = 0x38
set $CALR            = 0x3c
set $TAFCR           = 0x40
set $ALRMASSR        = 0x44
set $ALRMBSSR        = 0x48
set $BKP0R           = 0x50
set $BKP1R           = 0x54
set $BKP2R           = 0x58
set $BKP3R           = 0x5c
set $BKP4R           = 0x60
set $BKP5R           = 0x64
set $BKP6R           = 0x68
set $BKP7R           = 0x6c
set $BKP8R           = 0x70
set $BKP9R           = 0x74
set $BKP10R          = 0x78
set $BKP11R          = 0x7c
set $BKP12R          = 0x80
set $BKP13R          = 0x84
set $BKP14R          = 0x88
set $BKP15R          = 0x8c
set $BKP16R          = 0x90
set $BKP17R          = 0x94
set $BKP18R          = 0x98
set $BKP19R          = 0x9c

printf "loading print_rtc\n"

define print_rtc

    set $baseaddr = 0x40002800
    ###########################
    ##        TR             ##
    ###########################
    set $addr = $baseaddr + $TR
    set $data = *$addr
    printf "RTC.TR      0x%4x %4x: 0x%08x", ($addr >> 16), ($addr & 0xFFFF), *$addr 
    printf "     "
    printf "PM[22]=%d ", (($data >> 22) & 0x01)
    printf "HT[21:20]=%d ", (($data >> 20) & 0x03)
    printf "HU[19:16]=%d ", (($data >> 16) & 0x0f)
    printf "MNT[14:12]=%d ", (($data >> 12) & 0x07)
    printf "MNU[11:8]=%d ", (($data >> 8) & 0x0f)
    printf "ST[6:4]=%d ", (($data >> 4) & 0x07)
    printf "SU[3:0]=%d ", (($data >> 0) & 0x0f)
    printf "\n"

    ###########################
    ##        DR             ##
    ###########################
    set $addr = $baseaddr + $DR
    set $data = *$addr
    printf "RTC.DR      0x%4x %4x: 0x%08x", ($addr >> 16), ($addr & 0xFFFF), *$addr 
    printf "     "
    printf "YT[23:20]=%d ", (($data >> 20) & 0x0f)
    printf "YU[19:16]=%d ", (($data >> 16) & 0x0f)
    printf "WDU[15:13]=%d ", (($data >> 13) & 0x07)
    printf "MT[12]=%d ", (($data >> 12) & 0x01)
    printf "MU[11:8]=%d ", (($data >> 8) & 0x0f)
    printf "DT[5:4]=%d ", (($data >> 4) & 0x03)
    printf "DU[3:0]=%d ", (($data >> 0) & 0x0f)
    printf "\n"

    ###########################
    ##        CR             ##
    ###########################
    set $addr = $baseaddr + $CR
    set $data = *$addr
    printf "RTC.CR      0x%4x %4x: 0x%08x", ($addr >> 16), ($addr & 0xFFFF), *$addr 
    printf "     "
    printf "COE[23]=%d ", (($data >> 23) & 0x01)
    printf "OSEL[22:21]=%d ", (($data >> 21) & 0x03)
    printf "POL[20]=%d ", (($data >> 20) & 0x01)
    printf "COSEL[19]=%d ", (($data >> 19) & 0x01)
    printf "BKP[18]=%d ", (($data >> 18) & 0x01)
    printf "SUB1H[17]=%d ", (($data >> 17) & 0x01)
    printf "ADD1H[16]=%d ", (($data >> 16) & 0x01)
    printf "TSIE[15]=%d ", (($data >> 15) & 0x01)
    printf "WUTIE[14]=%d ", (($data >> 14) & 0x01)
    printf "ALRBIE[13]=%d ", (($data >> 13) & 0x01)
    printf "ALRAIE[12]=%d ", (($data >> 12) & 0x01)
    printf "TSE[11]=%d ", (($data >> 11) & 0x01)
    printf "WUTE[10]=%d ", (($data >> 10) & 0x01)
    printf "ALRBE[9]=%d ", (($data >> 9) & 0x01)
    printf "ALRAE[8]=%d ", (($data >> 8) & 0x01)
    printf "DCE[7]=%d ", (($data >> 7) & 0x01)
    printf "FMT[6]=%d ", (($data >> 6) & 0x01)
    printf "BYPSHAD[5]=%d ", (($data >> 5) & 0x01)
    printf "REFCKON[4]=%d ", (($data >> 4) & 0x01)
    printf "TSEDGE[3]=%d ", (($data >> 3) & 0x01)
    printf "WCKSEL[2:0]=%d ", (($data >> 0) & 0x07)
    printf "\n"

    ###########################
    ##        ISR            ##
    ###########################
    set $addr = $baseaddr + $ISR
    set $data = *$addr
    printf "RTC.ISR     0x%4x %4x: 0x%08x", ($addr >> 16), ($addr & 0xFFFF), *$addr 
    printf "     "
    printf "RECALPF[16]=%d ", (($data >> 16) & 0x01)
    printf "TAMP2F[14]=%d ", (($data >> 14) & 0x01)
    printf "TAMP1F[13]=%d ", (($data >> 13) & 0x01)
    printf "TSOVF[12]=%d ", (($data >> 12) & 0x01)
    printf "TSF[11]=%d ", (($data >> 11) & 0x01)
    printf "WUTF[10]=%d ", (($data >> 10) & 0x01)
    printf "ALRBF[9]=%d ", (($data >> 9) & 0x01)
    printf "ALRAF[8]=%d ", (($data >> 8) & 0x01)
    printf "INIT[7]=%d ", (($data >> 7) & 0x01)
    printf "INITF[6]=%d ", (($data >> 6) & 0x01)
    printf "RSF[5]=%d ", (($data >> 5) & 0x01)
    printf "INITS[4]=%d ", (($data >> 4) & 0x01)
    printf "SHPF[3]=%d ", (($data >> 3) & 0x01)
    printf "WUTWF[2]=%d ", (($data >> 2) & 0x01)
    printf "ALRBWF[1]=%d ", (($data >> 1) & 0x01)
    printf "ALRAWF[0]=%d ", (($data >> 0) & 0x01)
    printf "\n"

    ###########################
    ##        PRER           ##
