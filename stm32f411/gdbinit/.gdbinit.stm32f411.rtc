    printf "CALW8[14]=%d ", (($data >> 14) & 0x01)
    printf "CALW16[13]=%d ", (($data >> 13) & 0x01)
    printf "CALM[8:0]=%d ", (($data >> 0) & 0x1ff)
    printf "\n"

    ###########################
