    printf "TSINSEL[17]=%d ", (($data >> 17) & 0x01)
    printf "TAMP1INSEL[16]=%d ", (($data >> 16) & 0x01)
    printf "TAMPPUDIS[15]=%d ", (($data >> 15) & 0x01)
    printf "TAMPPRCH[14:13]=%d ", (($data >> 13) & 0x03)
    printf "TAMPFLT[12:11]=%d ", (($data >> 11) & 0x03)
    printf "TAMPFREQ[10:8]=%d ", (($data >> 8) & 0x07)
    printf "TAMPTS[7]=%d ", (($data >> 7) & 0x01)
    printf "TAMP2TRG[4]=%d ", (($data >> 4) & 0x01)
    printf "TAMP2E[3]=%d ", (($data >> 3) & 0x01)
    printf "TAMPIE[2]=%d ", (($data >> 2) & 0x01)
    printf "TAMP1TRG[1]=%d ", (($data >> 1) & 0x01)
    printf "TAMP1E[0]=%d ", (($data >> 0) & 0x01)
