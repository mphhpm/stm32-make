    printf "RTC.PRER    0x%4x %4x: 0x%08x", ($addr >> 16), ($addr & 0xFFFF), *$addr 
    printf "     "
    printf "PREDIV_A[22:16]=%d ", (($data >> 16) & 0x7f)
    printf "PREDIV_S[14:0]=%d ", (($data >> 0) & 0x7fff)
    printf "\n"

    ###########################
    ##        WUTR           ##
    ###########################
    set $addr = $baseaddr + $WUTR
    set $data = *$addr
    printf "RTC.WUTR    0x%4x %4x: 0x%08x", ($addr >> 16), ($addr & 0xFFFF), *$addr 
