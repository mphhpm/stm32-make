####
#### NVIC
set $ISER0           = 0x0
set $ISER1           = 0x4
set $ISER2           = 0x8
set $ICER0           = 0x80
set $ICER1           = 0x84
set $ICER2           = 0x88
set $ISPR0           = 0x100
set $ISPR1           = 0x104
set $ISPR2           = 0x108
set $ICPR0           = 0x180
set $ICPR1           = 0x184
set $ICPR2           = 0x188
set $IABR0           = 0x200
set $IABR1           = 0x204
set $IABR2           = 0x208
set $IPR0            = 0x300
set $IPR1            = 0x304
set $IPR2            = 0x308
set $IPR3            = 0x30c
set $IPR4            = 0x310
set $IPR5            = 0x314
set $IPR6            = 0x318
set $IPR7            = 0x31c
set $IPR8            = 0x320
set $IPR9            = 0x324
set $IPR10           = 0x328
set $IPR11           = 0x32c
set $IPR12           = 0x330
set $IPR13           = 0x334
set $IPR14           = 0x338
set $IPR15           = 0x33c
set $IPR16           = 0x340
set $IPR17           = 0x344
set $IPR18           = 0x348
set $IPR19           = 0x34c

define print_nvic

    set $baseaddr = 0xe000e100
    ###########################
    ##        ISER0          ##
    ###########################
    set $addr = $baseaddr + $ISER0
    printf "NVIC.ISER0   0x%4x %4x: 0x%08x", ($addr >> 16), ($addr & 0xFFFF), *$addr 
    printf "\n"

    ###########################
    ##        ISER1          ##
    ###########################
    set $addr = $baseaddr + $ISER1
    printf "NVIC.ISER1   0x%4x %4x: 0x%08x", ($addr >> 16), ($addr & 0xFFFF), *$addr 
    printf "\n"

    ###########################
    ##        ISER2          ##
    ###########################
