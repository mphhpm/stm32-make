    set $addr = $baseaddr + $IPR0
    printf "NVIC.IPR0    0x%4x %4x: 0x%08x", ($addr >> 16), ($addr & 0xFFFF), *$addr 
    printf "     "
    printf "IPR_N3:%d ", (($addr >> 24) & 0xff)
    printf "IPR_N2:%d ", (($addr >> 16) & 0xff)
    printf "IPR_N1:%d ", (($addr >> 8) & 0xff)
    printf "IPR_N0:%d ", (($addr >> 0) & 0xff)
    printf "\n"

